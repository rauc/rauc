#!/usr/bin/env python3

import argparse
import configparser
import os
import sys


def main():
    parser = argparse.ArgumentParser(
        description="bg_printenv mock for RAUC testing (use EFIBOOTGUARD_VAR_FILE for persisting data)"
    )
    parser.add_argument("--raw", action="store_true", help="Output raw variable values")
    parser.add_argument("-p", dest="partition", help="Select EFI partition")
    args = parser.parse_args()

    vars_file = os.environ.get("EFIBOOTGUARD_VAR_FILE")
    if not vars_file:
        print("Error: EFIBOOTGUARD_VAR_FILE not set", file=sys.stderr)
        sys.exit(1)

    cfg = configparser.ConfigParser()
    cfg.optionxform = str  # preserve key case
    cfg.read(vars_file)

    if not args.partition or not cfg.has_section(args.partition):
        print(f"Error: partition {args.partition!r} not found", file=sys.stderr)
        sys.exit(1)

    for key, value in cfg.items(args.partition):
        print(f"{key}={value}")


if __name__ == "__main__":
    main()
