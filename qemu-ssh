#!/bin/sh
#
# Helper script to connect via SSH to a running qemu-test VM
#
# Usage: ./qemu-ssh [ssh-arguments...]
#

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

exec ssh \
  -o StrictHostKeyChecking=no \
  -o UserKnownHostsFile=/dev/null \
  -o LogLevel=ERROR \
  -i "$SCRIPT_DIR/qemu-test-ssh-key" \
  -p 2222 \
  root@127.0.0.1 \
  "$@"
